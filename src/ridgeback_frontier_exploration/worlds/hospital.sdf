<?xml version="1.0"?>
<sdf version="1.9">
  <world name="hospital">

    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics"/>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands"/>
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster"/>
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <gravity>0 0 -9.81</gravity>

    <scene>
      <ambient>0.72 0.72 0.72 1</ambient>
      <background>0.96 0.97 0.99 1</background>
      <shadows>true</shadows>
    </scene>

    <physics name="default_physics" type="ode">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>500</real_time_update_rate>
    </physics>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 12 0 0 0</pose>
      <diffuse>0.95 0.95 0.95 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.25 0.15 -1</direction>
    </light>

    <model name="hospital_floor">
      <static>true</static>
      <pose>5 0 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <box><size>24 18 0.1</size></box>
          </geometry>
        </collision>
        <visual name="vis">
          <geometry>
            <box><size>24 18 0.1</size></box>
          </geometry>
          <material>
            <ambient>0.92 0.92 0.92 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="corridor_strip">
      <static>true</static>
      <pose>5 0 0.051 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry>
            <box><size>20 2.9 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.88 0.90 0.93 1</ambient>
            <diffuse>0.88 0.90 0.93 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Outer shell -->
    <model name="wall_west"><static>true</static><pose>-6 0 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>0.2 16 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.2 16 2.8</size></box></geometry><material><ambient>0.98 0.98 0.99 1</ambient><diffuse>0.98 0.98 0.99 1</diffuse></material></visual></link>
    </model>
    <model name="wall_east"><static>true</static><pose>16 0 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>0.2 16 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.2 16 2.8</size></box></geometry><material><ambient>0.98 0.98 0.99 1</ambient><diffuse>0.98 0.98 0.99 1</diffuse></material></visual></link>
    </model>
    <model name="wall_north"><static>true</static><pose>5 8 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>22 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>22 0.2 2.8</size></box></geometry><material><ambient>0.98 0.98 0.99 1</ambient><diffuse>0.98 0.98 0.99 1</diffuse></material></visual></link>
    </model>
    <model name="wall_south"><static>true</static><pose>5 -8 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>22 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>22 0.2 2.8</size></box></geometry><material><ambient>0.98 0.98 0.99 1</ambient><diffuse>0.98 0.98 0.99 1</diffuse></material></visual></link>
    </model>

    <!-- Corridor north wall with wide door gaps at x=4 and x=10 -->
    <model name="north_seg_1"><static>true</static><pose>-1.4 1.6 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>8.2 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>8.2 0.2 2.8</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
    </model>
    <model name="north_seg_2"><static>true</static><pose>7.0 1.6 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>3.4 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>3.4 0.2 2.8</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
    </model>
    <model name="north_seg_3"><static>true</static><pose>13.6 1.6 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>4.8 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>4.8 0.2 2.8</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
    </model>

    <!-- Corridor south wall with wide door gaps at x=4 and x=10 -->
    <model name="south_seg_1"><static>true</static><pose>-1.4 -1.6 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>8.2 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>8.2 0.2 2.8</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
    </model>
    <model name="south_seg_2"><static>true</static><pose>7.0 -1.6 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>3.4 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>3.4 0.2 2.8</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
    </model>
    <model name="south_seg_3"><static>true</static><pose>13.6 -1.6 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>4.8 0.2 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>4.8 0.2 2.8</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
    </model>

    <!-- Room separators -->
    <model name="north_divider"><static>true</static><pose>7 4.8 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>0.2 6.4 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.2 6.4 2.8</size></box></geometry><material><ambient>0.99 0.99 0.99 1</ambient><diffuse>0.99 0.99 0.99 1</diffuse></material></visual></link>
    </model>
    <model name="south_divider"><static>true</static><pose>7 -4.8 1.4 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>0.2 6.4 2.8</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.2 6.4 2.8</size></box></geometry><material><ambient>0.99 0.99 0.99 1</ambient><diffuse>0.99 0.99 0.99 1</diffuse></material></visual></link>
    </model>

    <!-- Basic hospital furniture (visual realism) -->
    <model name="bed_n1"><static>true</static><pose>4.0 5.8 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.8 0.9 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.8 0.9 0.5</size></box></geometry><material><ambient>0.78 0.88 0.95 1</ambient><diffuse>0.78 0.88 0.95 1</diffuse></material></visual>
      </link>
    </model>
    <model name="bed_n2"><static>true</static><pose>10.0 5.8 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.8 0.9 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.8 0.9 0.5</size></box></geometry><material><ambient>0.78 0.88 0.95 1</ambient><diffuse>0.78 0.88 0.95 1</diffuse></material></visual>
      </link>
    </model>
    <model name="bed_s1"><static>true</static><pose>4.0 -5.8 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.8 0.9 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.8 0.9 0.5</size></box></geometry><material><ambient>0.78 0.88 0.95 1</ambient><diffuse>0.78 0.88 0.95 1</diffuse></material></visual>
      </link>
    </model>
    <model name="bed_s2"><static>true</static><pose>10.0 -5.8 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.8 0.9 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.8 0.9 0.5</size></box></geometry><material><ambient>0.78 0.88 0.95 1</ambient><diffuse>0.78 0.88 0.95 1</diffuse></material></visual>
      </link>
    </model>

    <model name="nurse_desk"><static>true</static><pose>-4.2 -2.6 0.45 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.8 0.6 0.9</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.8 0.6 0.9</size></box></geometry><material><ambient>0.72 0.74 0.77 1</ambient><diffuse>0.72 0.74 0.77 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Target sphere in forward room -->
    <light type="point" name="sphere_light">
      <pose>10.2 5.0 2.0 0 0 0</pose>
      <diffuse>1 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>12</range>
        <constant>0.7</constant>
        <linear>0.02</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <model name="red_sphere">
      <static>true</static>
      <pose>10.2 5.0 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><sphere><radius>0.3</radius></sphere></geometry>
        </collision>
        <visual name="visual">
          <geometry><sphere><radius>0.3</radius></sphere></geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
            <specular>0.4 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>